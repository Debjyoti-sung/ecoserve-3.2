# npm Configuration for EcoServe Platform

# Use exact versions from lock file
save-exact=true

# Always use https
registry=https://registry.npmjs.org/

# Strict SSL verification
strict-ssl=true

# Audit mode
audit=true

# Legacy peer deps handling
legacy-peer-deps=false

# Prefer offline for cached packages
prefer-offline=true

# Save npm logs
loglevel=warn
